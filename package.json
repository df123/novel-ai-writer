{
  "name": "novel-ai-writer",
  "version": "1.0.0",
  "description": "LLM辅助小说写作工具",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:renderer\"",
    "dev:server": "node src/server/index.js",
    "dev:renderer": "vite",
    "start:server": "lsof -ti:3002 | xargs kill -9 2>/dev/null; node src/server/index.js",
    "start:renderer": "lsof -ti:3004 | xargs kill -9 2>/dev/null; vite",
    "build:renderer": "vite build",
    "build": "pnpm run build:renderer",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.0.6",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "sql.js": "^1.10.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
