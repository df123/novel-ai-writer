{
  "name": "novel-ai-writer",
  "version": "1.0.0",
  "type": "module",
  "description": "LLM辅助小说写作工具",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:renderer\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:renderer": "vite",
    "start:server": "lsof -ti:3002 | xargs kill -9 2>/dev/null; tsx src/server/index.ts",
    "start:renderer": "lsof -ti:3004 | xargs kill -9 2>/dev/null; vite",
    "build:renderer": "vite build",
    "build": "pnpm run build:renderer",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.vue",
    "typecheck": "tsc --noEmit",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.0.6",
    "element-plus": "^2.5.0",
    "express": "^4.18.2",
    "marked": "^17.0.4",
    "pinia": "^2.1.7",
    "sql.js": "^1.10.3",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
