{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "outDir": "dist/preload",
    "rootDir": "src/preload",
    "types": ["electron"]
  },
  "include": ["src/preload/**/*"],
  "exclude": ["node_modules"]
}
